{
  "name": "dragonclaw",
  "version": "0.0.1",
  "description": "DragonClaw Agent Desktop Client for OpenClaw",
  "homepage": "https://github.com/Leon-PanPan/dragonclaw",
  "main": "src/main/index.js",
  "author": "杨里卬",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "vite --mode development",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently --kill-others --success first \"npm run dev\" \"wait-on http-get://127.0.0.1:5177 --timeout 60000 --interval 1000 && electron . --dev --no-sandbox\"",
    "build:win": "npx vite build && node scripts/_mirror.mjs -- electron-builder --win",
    "build:mac": "npx vite build && node scripts/_mirror.mjs -- electron-builder --mac",
    "build:mac-arm64": "npx vite build && node scripts/_mirror.mjs -- electron-builder --mac dmg --arm64",
    "build:mac-x64": "npx vite build && node scripts/_mirror.mjs -- electron-builder --mac dmg --x64",
    "build:linux": "npx vite build && node scripts/_mirror.mjs -- electron-builder --linux AppImage",
    "build:linux:deb": "npx vite build && node scripts/_mirror.mjs --github-only -- electron-builder --linux deb",
    "build:all": "node scripts/build-all.mjs",
    "build:all:cross": "npx vite build && node scripts/_mirror.mjs -- electron-builder --win --mac --linux",
    "build:all:dry": "node scripts/build-all.mjs --dry-run",
    "build:all:npm": "node scripts/build-all.mjs --no-vite",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "dependencies": {
    "@arco-design/web-vue": "^2.53.0",
    "@noble/ed25519": "^3.0.1",
    "axios": "^1.6.0",
    "highlight.js": "^11.9.0",
    "markdown-it": "^13.0.0",
    "pinia": "^2.1.0",
    "socket.io-client": "^4.6.0",
    "sql.js": "^1.14.1",
    "vue": "^3.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@streamparser/json": "^0.0.22",
    "@vitejs/plugin-vue": "^4.4.0",
    "concurrently": "^8.2.0",
    "electron": "^41.0.3",
    "electron-builder": "^24.0.0",
    "electron-fix": "^1.1.7",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "sass": "^1.100.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.dragonclaw.app",
    "productName": "DragonClaw",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "src/assets/**/*",
      "src/shared/**/*",
      "shared/**/*",
      "renderer/dist/**/*",
      "package.json",
      "!src/renderer/node_modules/**/*",
      "!**/node_modules/**/{CHANGELOG.md,README.md,README,readme.md,readme,*.md,*.markdown}",
      "!**/node_modules/**/*.{map,ts,tsx,jsx,d.ts,d.mts}",
      "!**/node_modules/**/{test,__tests__,tests,powered-test,example,examples,docs,doc,coverage}",
      "!**/node_modules/**/*.{less,sass,scss,styl}",
      "!**/node_modules/.bin",
      "!**/node_modules/**/{.editorconfig,.eslintrc*,.prettierrc*,.nycrc*,babel.config*,rollup.config*,webpack.config*,jest.config*,tsconfig*,.babelrc}"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] }
      ],
      "icon": "src/assets/icons/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": 2052,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DragonClaw",
      "uninstallDisplayName": "DragonClaw"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "src/assets/icons/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb", "arch": ["x64", "arm64"] }
      ],
      "icon": "src/assets/icons",
      "category": "Development",
      "synopsis": "Smart Desktop Client for OpenClaw Agent Platform",
      "description": "DragonClaw Agent Desktop Client for OpenClaw",
      "maintainer": "杨里卬 <noreply@dragonclaw.local>",
      "vendor": "DragonClaw"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ],
      "priority": "optional"
    }
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "4.60.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "@parcel/watcher",
      "electron",
      "esbuild",
      "vue-demi"
    ]
  }
}
